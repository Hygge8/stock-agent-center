# =====================
# Stock Agent Center
# =====================

# Web
SERVER_HOST=0.0.0.0
SERVER_PORT=9000

# Database
DATABASE_URL=sqlite:///database/stock_agent.db

# =====================
# Single Deploy Mode
# =====================
# 默认只部署 stock-agent-center，本 docker-compose 会自动启动内置 uzi-server。
# agent-center 通过容器网络访问 uzi-server，不需要用户单独部署 UZI-Skill。
UZI_API_URL=http://uzi-server:8977
UZI_DEFAULT_DEPTH=deep
UZI_REQUEST_TIMEOUT=30

# =====================
# Built-in Stock Scanner
# =====================
# 内置轻量股票池扫描，替代 daily_stock_analysis 的基础“发现机会”能力。
# 多个股票用英文逗号分隔。
STOCK_POOL=VGT,SPCX,DRAM,QLD,TQQQ,NVDA,TSLA,QQQM,QQQ
SCAN_PERIOD=3mo
SCAN_INTERVAL=1d
AUTO_SUBMIT_SCAN_RESULTS=true

# =====================
# Optional external daily_stock_analysis
# =====================
# v0.1 默认不需要单独部署 daily_stock_analysis。
# 如果以后要接外部 daily_stock_analysis，再打开这里。
DAILY_API_URL=http://daily-server:8000
ENABLE_DAILY_SYNC=false

# =====================
# Rule Engine
# =====================
DEEP_SCORE_THRESHOLD=85
MEDIUM_SCORE_THRESHOLD=70

# =====================
# DingTalk
# =====================
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
ENABLE_DINGTALK_NOTIFY=false

# =====================
# Scheduler
# =====================
ENABLE_SCHEDULE=false
SCAN_TIME=18:00
SCHEDULE_DEPTH=deep
