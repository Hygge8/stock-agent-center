# =====================
# Stock Agent Center
# =====================

# Web
SERVER_HOST=0.0.0.0
SERVER_PORT=9000

# Database
DATABASE_URL=sqlite:///database/stock_agent.db

# =====================
# One Repository Deployment
# =====================
# 只部署 stock-agent-center 一个仓库。
# docker-compose 会自动启动：
# - stock-agent-center
# - embedded daily_stock_analysis
# - embedded UZI-Skill

# =====================
# Embedded daily_stock_analysis
# =====================
DAILY_REPO_CONTEXT=https://github.com/Hygge8/daily_stock_analysis.git#fix/dingtalk-web-settings
DAILY_WEB_PORT=8000
DAILY_API_URL=http://daily-server:8000
ENABLE_DAILY_SYNC=true

# daily 自选股 / 股票池
STOCK_POOL=VGT,SPCX,DRAM,QLD,TQQQ,NVDA,TSLA,QQQM,QQQ

# daily 常用可选配置
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
TUSHARE_TOKEN=
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=

# =====================
# Embedded UZI-Skill Web
# =====================
UZI_REPO=https://github.com/Hygge8/UZI-Skill.git
UZI_REF=feature/uzi-web-docker
UZI_WEB_PORT=8977
UZI_API_URL=http://uzi-server:8977
UZI_DEFAULT_DEPTH=deep
UZI_WEB_DEFAULT_DEPTH=lite
UZI_REQUEST_TIMEOUT=30
UZI_WEB_MAX_PARALLEL_JOBS=1
UZI_WEB_MAX_QUEUE_SIZE=30

# =====================
# Built-in Stock Scanner
# =====================
# stock-agent-center 自带一个轻量扫描器；daily_stock_analysis 也会作为完整系统启动。
SCAN_PERIOD=3mo
SCAN_INTERVAL=1d
AUTO_SUBMIT_SCAN_RESULTS=true

# =====================
# Rule Engine
# =====================
DEEP_SCORE_THRESHOLD=85
MEDIUM_SCORE_THRESHOLD=70

# =====================
# DingTalk
# =====================
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
ENABLE_DINGTALK_NOTIFY=false

# =====================
# Scheduler
# =====================
ENABLE_SCHEDULE=false
SCAN_TIME=18:00
SCHEDULE_DEPTH=deep
