# =====================
# Stock Agent Center
# =====================

# Web
SERVER_HOST=0.0.0.0
SERVER_PORT=9000

# Database
DATABASE_URL=sqlite:///database/stock_agent.db

# =====================
# UZI-Skill Web
# =====================
# 本机 Docker Desktop 访问宿主机 UZI Web，推荐用 host.docker.internal
UZI_API_URL=http://host.docker.internal:8977
UZI_DEFAULT_DEPTH=deep
UZI_REQUEST_TIMEOUT=30

# =====================
# daily_stock_analysis
# =====================
DAILY_API_URL=http://daily-server:8000
ENABLE_DAILY_SYNC=false

# =====================
# Rule Engine
# =====================
DEEP_SCORE_THRESHOLD=85
MEDIUM_SCORE_THRESHOLD=70

# =====================
# DingTalk
# =====================
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
ENABLE_DINGTALK_NOTIFY=false

# =====================
# Scheduler
# =====================
ENABLE_SCHEDULE=false
SCAN_TIME=18:00
SCHEDULE_TICKERS=NVDA,TSLA,QQQ
SCHEDULE_DEPTH=deep
